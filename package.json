{
  "name": "Tabs Pin",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:firefox",
    "dev:firefox": "node scripts/prepare-manifest.js firefox && web-ext run",
    "dev:chrome": "node scripts/prepare-manifest.js chrome",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:firefox": "node scripts/build.js firefox",
    "build:chrome": "node scripts/build.js chrome",
    "start": "npm run dev",
    "lint": "node scripts/prepare-manifest.js firefox && web-ext lint"
  },
  "devDependencies": {
    "web-ext": "^10.1.0"
  }
}